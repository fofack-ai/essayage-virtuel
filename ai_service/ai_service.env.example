# =========================================================
# AI SERVICE — Variables d'environnement
# Ne jamais commiter ce fichier une fois rempli avec de vraies valeurs.
# =========================================================

# Token Hugging Face — RÉGÉNÉREZ-LE avant toute mise en production,
# l'ancien a circulé dans un fichier partagé.
# huggingface.co > Settings > Access Tokens
HF_TOKEN=change-me-regenerate-this-token
HF_CATVTON_SPACE=zhengchong/CatVTON

# Nombre d'étapes d'inférence CatVTON (30 = bon compromis qualité/quota gratuit)
AI_NUM_STEPS=30

# --- Fournisseur alternatif payant (FASHN) ---
# RÉGÉNÉREZ également cette clé avant la mise en production.
FASHN_API_KEY=change-me-regenerate-this-key
FASHN_BASE_URL=https://api.fashn.ai/v1

# "catvton" (gratuit, quota ZeroGPU limité) ou "fashn" (payant, plus fiable en prod)
AI_TRYON_STRATEGY=fashn

# Ne JAMAIS mettre à true en production
AI_DEBUG_FALLBACK=false
