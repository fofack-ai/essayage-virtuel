# =========================================================
# BACKEND — Variables d'environnement
# Ne jamais commiter ce fichier une fois rempli avec de vraies valeurs.
# Sur Render : Dashboard > votre service > Environment > ajoutez ces clés une par une.
# =========================================================

# Port (Render fournit automatiquement sa propre variable PORT, laissez le code
# utiliser process.env.PORT || 5000, ne fixez pas cette valeur en dur sur Render)
PORT=5000

# --- Base de données MySQL (Aiven) ---
# Sur Aiven : Service > Overview > Connection information
DB_HOST=your-service-name.aivencloud.com
DB_USER=avnadmin
DB_PASSWORD=change-me
DB_NAME=defaultdb
DB_PORT=your-aiven-port
# Aiven impose SSL : téléchargez le certificat CA depuis la console Aiven
# et référencez son chemin dans votre config MySQL (ssl: { ca: fs.readFileSync(...) })

# --- JWT ---
# Générez une nouvelle valeur avec : openssl rand -base64 48
JWT_SECRET=change-me-generate-a-new-long-random-value

# --- SMTP (envoi d'e-mails, ex: Gmail avec mot de passe d'application) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-adresse@gmail.com
SMTP_PASS=change-me-app-password
SMTP_FROM="CFPD TryOn <votre-adresse@gmail.com>"

# --- Frontend (redirection après authentification) ---
# Une ou plusieurs origines séparées par des virgules (voir cors.js fourni)
FRONTEND_URL=https://www.votredomaine.com,https://votredomaine.com

# --- Service IA (essayage virtuel) ---
AI_SERVICE_URL=https://ai.votredomaine.com
AI_TRYON_STRATEGY=fashn

# --- Authentification Google (OAuth2) ---
# Google Cloud Console > APIs & Services > Identifiants
GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me
GOOGLE_CALLBACK_URL=https://api.votredomaine.com/api/v1/auth/google/callback

# --- URL publique du backend (callback Paydunya, etc.) ---
BACKEND_URL=https://api.votredomaine.com

# --- Paydunya ---
PAYDUNYA_MODE=test
PAYDUNYA_MASTER_KEY=change-me
PAYDUNYA_PRIVATE_KEY=change-me
PAYDUNYA_TOKEN=change-me
PAYDUNYA_PUBLIC_KEY=change-me

# --- Cloudinary (nouveau — remplace le stockage disque local) ---
CLOUDINARY_CLOUD_NAME=change-me
CLOUDINARY_API_KEY=change-me
CLOUDINARY_API_SECRET=change-me
